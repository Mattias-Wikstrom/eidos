/* Example theory using the abbreviations section.
   Abbreviation names must start with an uppercase letter. */
{
  signature {
    sort S;
    T subsort S;
  },
  abbreviations {
    Impl(x, y) := x ⇒ y; // "x implies y" as the reverse-difference x ⇒ y
    Join(x, y, z) := x + (y + z); // ternary join
    Closure(x) := x + (x ⇒ x);
  },
  axioms {
    metafacts {
      Impl(𝔻#min, 𝔻#max);
      Join(𝔻#min, 𝔻#min, 𝔻#min);
    }
  }
}
