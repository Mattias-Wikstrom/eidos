test-suite ir-tests
  import:           warnings, deps
  type:             exitcode-stdio-1.0
  main-is:          IRSpec.hs
  hs-source-dirs:   test
  default-language: GHC2021
  build-depends:    eidos-parser,
                    hspec >=2.0,
